---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Math introductions and tutorials for students" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        font-size: 16px;
        color: #111827;
        background-color: #f3f4f8;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }
    </style>
  </head>
  <body>
    <script id="wmt-widget-init-script" type="module" src="https://tools-cdn.webmonetization.org/widget.js" data-wallet-address="https://ilp.link/darian" data-tag="version1"></script>
    <script id="wmt-banner-init-script" type="module" src="https://tools-cdn.webmonetization.org/banner.js" data-wallet-address="https://ilp.interledger-test.dev/darianeur" data-tag="version1"></script>
    <slot />
    <!-- <script>
      const params: { [key: string]: string } = {};
      new URLSearchParams(window.location.search).forEach((value, key) => {
        params[key] = value;
      });
      window.opener.postMessage({type: 'GRANT_INTERACTION', ...params}, '*');
      console.log('###Test message urlParams: ', new URLSearchParams(window.location.search).toString());
    </script> -->
  </body>
</html>
